{
  "extends": [
    "config:recommended",
    "default:pinDigestsDisabled",
    "mergeConfidence:all-badges",
    "docker:disable"
  ],
  "assignees": [
    "I539149",
    "d063094"
  ],
  "commitMessageAction": "Renovate: Update",
  "constraints": {
    "node": ">= 18"
  },
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "postUpdateOptions": [
    "npmDedupe"
  ],
  "prHourlyLimit": 0,
  "schedule": [
    "before 8am on Friday"
  ],
  "packageRules": [
    {
      "groupName": "miscellaneous packages",
      "description": "Group dependencies, specific groups can override",
      "schedule": [
        "before 8am on Friday"
      ],
      "separateMajorMinor": false,
      "matchPackagePatterns": [
        ".*"
      ]
    },
    {
      "groupName": "react packages",
      "description": "Updates for React and related packages separately",
      "schedule": [
        "before 8am on Friday"
      ],
      "matchPackagePatterns": [
        "^react(-dom|-test-renderer)?$"
      ]
    },
    {
      "groupName": "cloudoperators packages",
      "description": "Updates for all @cloudoperators packages separately",
      "schedule": [
        "before 8am on Friday"
      ],
      "matchPackagePatterns": [
        "^@?cloudoperators"
      ]
    },
    {
      "groupName": "tailwind packages",
      "description": "Updates for Tailwind and related packages separately",
      "matchPackagePatterns": [
        "^@?tailwindcss"
      ],
      "schedule": [
        "before 8am on Friday"
      ]
    },
    {
      "groupName": "eslint packages",
      "description": "Updates for eslint and related packages separately",
      "matchPackagePatterns": [
        "^@?eslint"
      ],
      "schedule": [
        "before 8am on Friday"
      ]
    }
  ],
  "semanticCommits": "disabled"
}
